{
  "name": "vitepress-open-md",
  "publisher": "chgeo",
  "displayName": "Open Markdown Document in VitePress",
  "icon": "assets/icon.png",
  "description": "Open the currently active markdown file in the running VitePress dev server.",
  "version": "0.3.0",
  "license": "MIT",
  "keywords": [
    "vitepress",
    "markdown",
    "browser",
    "documentation"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/chgeo/vitepress-open-md.git"
  },
  "homepage": "https://github.com/chgeo/vitepress-open-md#readme",
  "bugs": {
    "url": "https://github.com/chgeo/vitepress-open-md/issues"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:markdown",
    "onLanguage:mdx"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "vitepressMd.openCurrent",
        "title": "Open in VitePress",
        "icon": {
          "light": "assets/open-vitepress-light.svg",
          "dark": "assets/open-vitepress-dark.svg"
        }
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "vitepressMd.openCurrent",
          "when": "editorLangId =~ /^(markdown|mdx)$/",
          "group": "navigation@2"
        }
      ],
      "editor/title/context": [
        {
          "command": "vitepressMd.openCurrent",
          "when": "resourceLangId =~ /^(markdown|mdx)$/",
          "group": "1_open"
        }
      ],
      "explorer/context": [
        {
          "command": "vitepressMd.openCurrent",
          "when": "resourceLangId =~ /^(markdown|mdx)$/",
          "group": "navigation@1"
        }
      ]
    },
    "configuration": {
      "title": "VitePress Open Markdown",
      "properties": {
        "vitepressMd.baseUrl": {
          "type": "string",
          "default": "http://localhost:5173",
          "description": "Base URL of the running VitePress dev server."
        },
        "vitepressMd.rootFolder": {
          "type": "string",
          "default": "docs",
          "description": "Workspace folder that contains the VitePress root."
        },
        "vitepressMd.browserApp": {
          "type": "string",
          "default": "Google Chrome",
          "description": "macOS external browser app for tab reuse. Use Google Chrome, Safari, or another Chrome-family app name."
        },
        "vitepressMd.vsCodeCompatibleSlugs": {
          "type": "boolean",
          "default": false,
          "description": "Use a slugifier for URL headings compatible with VS Code's markdown editor. For example, 'Node.js' becomes '#nodejs' instead of standard '#node-js'."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p .",
    "watch": "tsc -watch -p .",
    "test": "npm run compile && node --test \"dist/**/*.test.js\"",
    "package": "npx vsce package"
  },
  "devDependencies": {
    "@types/chai": "^5.2.3",
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.90.0",
    "chai": "^5.1.1",
    "typescript": "^5.5.0"
  }
}
